# ==============================================================================
# Vakeel Saab Backend - Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and modify for local development.

# --- Application Configuration ---
APP_NAME="Vakeel Saab API"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database Configuration ---
# Standard URL format: postgresql://[user]:[password]@[host]:[port]/[database]
# If postgres is running locally inside docker, adjust host accordingly
DATABASE_URL=postgresql://vakeelsaab:change_me_in_production@localhost:5432/vakeelsaab_db

# --- Security (JWT authentication) ---
# Secrets should match a securely randomized 32+ characters hex string in production
# E.g. generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Cross-Origin Resource Sharing (CORS) ---
# JSON formatted list of allowed domains
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://127.0.0.1:3000"]

# --- File Storage Configuration ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
