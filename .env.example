# ============================================
# Vakeel Saab - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Vakeel Saab
NEXT_PUBLIC_APP_TAGLINE=AI Powered Multi-Agent Legal Intelligence Platform

# ---- Backend ----
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- Database ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=vakeelsaab
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=vakeelsaab_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Authentication ----
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- AI / LLM (Placeholders - Do NOT implement) ----
# OPENAI_API_KEY=sk-placeholder
# ANTHROPIC_API_KEY=sk-placeholder
# EMBEDDING_MODEL=text-embedding-3-small
# LLM_MODEL=gpt-4o

# ---- Vector Store (Placeholder) ----
# PINECONE_API_KEY=placeholder
# PINECONE_INDEX=vakeelsaab-legal

# ---- Redis (Optional) ----
# REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- File Storage ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
